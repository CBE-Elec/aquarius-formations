/**
 * Cree le champ date de debut.
 */
function _aquarius_formations_create_date_debut_field(): void {
  if (!FieldStorageConfig::loadByName('group', 'field_formation_date_debut')) {
    FieldStorageConfig::create([
      'field_name' => 'field_formation_date_debut',
      'entity_type' => 'group',
      'type' => 'datetime',
      'cardinality' => 1,
      'settings' => [
        'datetime_type' => 'date',
      ],
    ])->save();
  }
  else {
    _aquarius_formations_ensure_date_debut_date_only();
  }

  if (!FieldConfig::loadByName('group', 'formation', 'field_formation_date_debut')) {
    FieldConfig::create([
      'field_name' => 'field_formation_date_debut',
      'entity_type' => 'group',
      'bundle' => 'formation',
      'label' => 'Date de debut',
      'required' => FALSE,
    ])->save();
  }
}

/**
 * Cree le champ etat de la formation.
 */
function _aquarius_formations_create_etat_field(): void {
  if (!FieldStorageConfig::loadByName('group', 'field_formation_etat')) {
    FieldStorageConfig::create([
      'field_name' => 'field_formation_etat',
      'entity_type' => 'group',
      'type' => 'list_string',
      'cardinality' => 1,
      'settings' => [
        'allowed_values' => [
          'pas_ouverte' => 'Pas encore ouverte',
          'inscriptions_ouvertes' => 'Inscriptions ouvertes',
          'formation_en_cours' => 'Formation en cours',
          'formation_terminee' => 'Formation terminee',
        ],
      ],
    ])->save();
  }

  if (!FieldConfig::loadByName('group', 'formation', 'field_formation_etat')) {
    FieldConfig::create([
      'field_name' => 'field_formation_etat',
      'entity_type' => 'group',
      'bundle' => 'formation',
      'label' => 'Etat de la formation',
      'required' => TRUE,
      'default_value' => [
        ['value' => 'pas_ouverte'],
      ],
    ])->save();
  }
}

