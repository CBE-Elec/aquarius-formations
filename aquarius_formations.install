/**
 * Cree le champ etat de la formation.
 */
function _aquarius_formations_create_etat_field(): void {
  if (!FieldStorageConfig::loadByName('group', 'field_formation_etat')) {
    FieldStorageConfig::create([
      'field_name' => 'field_formation_etat',
      'entity_type' => 'group',
      'type' => 'list_string',
      'cardinality' => 1,
      'settings' => [
        'allowed_values' => [
          'pas_ouverte' => 'Pas encore ouverte',
          'inscriptions_ouvertes' => 'Inscriptions ouvertes',
          'formation_en_cours' => 'Formation en cours',
          'formation_terminee' => 'Formation terminee',
        ],
      ],
    ])->save();
  }

  if (!FieldConfig::loadByName('group', 'formation', 'field_formation_etat')) {
    FieldConfig::create([
      'field_name' => 'field_formation_etat',
      'entity_type' => 'group',
      'bundle' => 'formation',
      'label' => 'Etat de la formation',
      'required' => TRUE,
      'default_value' => [
        ['value' => 'pas_ouverte'],
      ],
    ])->save();
  }
}

// ---------------------------------------------------------------------------
// Structure Evaluation de formation (node type)
// ---------------------------------------------------------------------------

/**
 * Cree le type de noeud evaluation_formation.
 */
function _aquarius_formations_create_evaluation_node_type(): void {
  if (NodeType::load('evaluation_formation')) {
    return;
  }

  NodeType::create([
    'type' => 'evaluation_formation',
    'name' => 'Evaluation de formation',
    'description' => "Formulaire d'evaluation d'un eleve pour une formation.",
    'new_revision' => FALSE,
    'display_submitted' => FALSE,
  ])->save();
}

/**
 * Cree tous les champs du node type evaluation_formation.
 */
function _aquarius_formations_create_evaluation_fields(): void {
  _aquarius_formations_create_eval_formation_field();
  _aquarius_formations_create_eval_eleve_field();
  _aquarius_formations_create_eval_encadrant_field();
  _aquarius_formations_create_eval_date_field();
  _aquarius_formations_create_eval_conditions_field();
  _aquarius_formations_create_eval_sortie_field();
  _aquarius_formations_create_eval_commentaire_field();
}

/**
 * Champ : formation associee (groupe de type formation).
 */
