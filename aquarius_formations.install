/**
 * Cree le format de date utilise pour les formations.
 */
function _aquarius_formations_ensure_date_format(): void {
  if (DateFormat::load('aquarius_date')) {
    return;
  }

  DateFormat::create([
    'id' => 'aquarius_date',
    'label' => 'Date Aquarius',
    'pattern' => 'd/m/Y',
  ])->save();
}

/**
 * Force le champ Date de debut en stockage date-only.
 */
function _aquarius_formations_ensure_date_debut_date_only(): void {
  $storage = FieldStorageConfig::loadByName('group', 'field_formation_date_debut');
  if (!$storage || $storage->getSetting('datetime_type') === 'date') {
    return;
  }

  $storage->setSetting('datetime_type', 'date');
  $storage->save();
}

/**
 * Cree les vues du module a partir des YAML dans config/optional.
 */
function _aquarius_formations_sync_views_config(): void {
  $module_path = \Drupal::service('extension.list.module')->getPath('aquarius_formations');
  $default_config = new FileStorage(DRUPAL_ROOT . '/' . $module_path . '/config/optional');

  $config_names = [
    'views.view.niveaux_ffessm',
    'views.view.formation',
    'views.view.formation_membres',
  ];

  foreach ($config_names as $config_name) {
    $data = $default_config->read($config_name);
    if (!is_array($data) || $data === []) {
      continue;
    }

    $active = \Drupal::configFactory()->getEditable($config_name);
    if (!$active->isNew()) {
      continue;
    }

    $active->setData($data)->save();
  }
}

/**
 * Cree la vue niveaux_ffessm depuis config/optional si elle est absente.
 */
function _aquarius_formations_ensure_niveaux_ffessm_view(): void {
  $active = \Drupal::configFactory()->getEditable('views.view.niveaux_ffessm');
  if (!$active->isNew()) {
    return;
  }

  $module_path = \Drupal::service('extension.list.module')->getPath('aquarius_formations');
  $default_config = new FileStorage(DRUPAL_ROOT . '/' . $module_path . '/config/optional');
  $data = $default_config->read('views.view.niveaux_ffessm');
  if (!is_array($data) || $data === []) {
    return;
  }

  $active->setData($data)->save();
}
