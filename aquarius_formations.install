  }

  if (!FieldConfig::loadByName('group', 'formation', 'field_formation_saison')) {
    FieldConfig::create([
      'field_name' => 'field_formation_saison',
      'entity_type' => 'group',
      'bundle' => 'formation',
      'label' => 'Saison',
      'required' => FALSE,
      'settings' => [
        'handler' => 'default:group',
