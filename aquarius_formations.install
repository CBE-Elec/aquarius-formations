  if (!FieldStorageConfig::loadByName('node', 'field_eval_formation')) {
    FieldStorageConfig::create([
      'field_name' => 'field_eval_formation',
      'entity_type' => 'node',
      'type' => 'entity_reference',
      'cardinality' => 1,
      'settings' => ['target_type' => 'group'],
    ])->save();
  }

  if (!FieldConfig::loadByName('node', 'evaluation_formation', 'field_eval_formation')) {
    FieldConfig::create([
      'field_name' => 'field_eval_formation',
      'entity_type' => 'node',
      'bundle' => 'evaluation_formation',
      'label' => 'Formation',
      'required' => TRUE,
      'settings' => [
        'handler' => 'default:group',
        'handler_settings' => ['target_bundles' => ['formation' => 'formation']],
      ],
    ])->save();
  }
}

